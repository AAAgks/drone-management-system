root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,xml,yml,yaml,properties,ini,sql}]
charset = utf-8
indent_style = space
indent_size = 4

[*.{bat,cmd}]
charset = utf-8
end_of_line = crlf

[*.{json,js,vue,css,html}]
charset = utf-8
indent_style = space
indent_size = 2