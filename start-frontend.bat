REM ================================================================
REM  前端启动脚本
REM  1. 切换到 UTF-8 代码页
REM  2. 进入 frontend 目录
REM  3. 通过 npx 启动 Vite 开发服务器（端口 3000）
REM ================================================================
@echo off
chcp 65001 >nul
echo ========================================
echo   启动前端服务 (Vite 3000)
echo ========================================
cd /d "%~dp0frontend"
call D:\nvm\nodejs\npx.cmd vite
pause
